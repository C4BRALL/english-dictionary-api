{
  "name": "@english-dictionary/infrastructure",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "lint": "eslint src prisma.config.ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@english-dictionary/application": "workspace:*",
    "@english-dictionary/contracts": "workspace:*",
    "@english-dictionary/domain": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "argon2": "0.44.0",
    "bullmq": "5.78.0",
    "dotenv": "17.4.2",
    "ioredis": "5.10.1",
    "jose": "6.2.3",
    "pg": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@english-dictionary/typescript-config": "workspace:*",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.0.15",
    "eslint": "9.39.1",
    "prisma": "7.8.0",
    "typescript": "5.9.3",
    "vitest": "4.0.15"
  }
}
