{
  "name": "@english-dictionary/infrastructure",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@english-dictionary/application": "workspace:*",
    "@english-dictionary/contracts": "workspace:*",
    "@english-dictionary/domain": "workspace:*"
  },
  "devDependencies": {
    "@english-dictionary/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "4.0.15",
    "eslint": "9.39.1",
    "typescript": "5.9.3",
    "vitest": "4.0.15"
  }
}
