NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://dictionary:dictionary@localhost:5432/dictionary?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=english-dictionary-api
JWT_AUDIENCE=english-dictionary-client
JWT_EXPIRES_IN=1h
CORS_ORIGINS=http://localhost:3000
DICTIONARY_API_URL=https://api.dictionaryapi.dev
CACHE_LIST_TTL_SECONDS=300
CACHE_DETAIL_TTL_SECONDS=86400
FAVORITE_JOB_TIMEOUT_MS=10000
FAVORITE_WORKER_CONCURRENCY=5
WORDS_SOURCE_URL=https://raw.githubusercontent.com/dwyl/english-words/master/words_dictionary.json
IMPORT_BATCH_SIZE=5000
