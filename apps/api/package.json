{
  "name": "@english-dictionary/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@english-dictionary/application": "workspace:*",
    "@english-dictionary/contracts": "workspace:*",
    "@english-dictionary/domain": "workspace:*",
    "@english-dictionary/infrastructure": "workspace:*",
    "@nestjs/common": "11.1.26",
    "@nestjs/core": "11.1.26",
    "@nestjs/platform-express": "11.1.26",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/throttler": "6.5.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "helmet": "8.2.0",
    "nest-winston": "1.10.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@english-dictionary/typescript-config": "workspace:*",
    "@nestjs/testing": "11.1.26",
    "@types/express": "5.0.6",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.0.15",
    "eslint": "9.39.1",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.15"
  }
}
